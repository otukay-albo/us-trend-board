# Upstash Redis (Vercel Marketplace経由で自動注入される)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Cron認証 (任意の長い文字列)
CRON_SECRET=

# Apify (コスメ・ハッシュタグ。未設定ならデモデータで動く)
APIFY_TOKEN=
# コスメ: Amazon Best Sellers (US/Beauty) を cookie不要で取得
APIFY_BEAUTY_ACTOR=khadinakbar/amazon-bestsellers-scraper
# ハッシュタグ: Creative Center (US/Beauty&Personal Care/Last7days) を cookie不要で実データ取得
APIFY_HASHTAG_ACTOR=data_xplorer/tiktok-trends
