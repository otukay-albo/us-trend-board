# Upstash Redis (Vercel Marketplace経由で自動注入される)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Cron認証 (任意の長い文字列)
CRON_SECRET=

# Apify (コスメ・ハッシュタグ。未設定ならデモデータで動く)
APIFY_TOKEN=
# コスメ: Amazon Best Sellers (US/Beauty) を cookie不要で取得
APIFY_BEAUTY_ACTOR=khadinakbar/amazon-bestsellers-scraper
# ハッシュタグ: Creative Center (US/Beauty&Personal Care/Last7days) を実データ取得
APIFY_HASHTAG_ACTOR=doliz/tiktok-creative-center-scraper
# ↑doliz はcookie必須。ブラウザのads.tiktok.comのcookie文字列を丸ごと。数日で期限切れ→要再取得
TIKTOK_CC_COOKIE=
