# Upstash Redis (Vercel Marketplace経由で自動注入される)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Cron認証 (任意の長い文字列)
CRON_SECRET=

# Apify (コスメ・ハッシュタグ。未設定ならデモデータで動く)
APIFY_TOKEN=
APIFY_BEAUTY_ACTOR=    # 例: username~amazon-best-sellers-scraper
# ハッシュタグ: Creative Center (US/Beauty&Personal Care/Last7days) を cookie不要で取得
APIFY_HASHTAG_ACTOR=khadinakbar/tiktok-trending-hashtags-scraper
